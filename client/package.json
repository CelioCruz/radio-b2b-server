{
  "name": "devsistem-audio",
  "productName": "DevSistem Audio",
  "version": "1.0.0",
  "description": "Sistema de Rádio B2B Profissional",
  "author": "Celio Cruz - Devsistem",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.devsistem.audio",
    "productName": "DevSistem Audio",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "scr/preload.js",
      "radio.png"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "C_logo.png",
      "publisherName": "DevSistem"
    },
    "portable": {
      "artifactName": "DevSistemAudio_Portable.exe",
      "requestExecutionLevel": "user"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "DevSistem Audio"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.12"
  }
}